@startuml sequence-diagram
title authz-playground — Evaluation Sequence

actor User
participant "CLI" as cli
participant "Lexer" as lex
participant "Parser" as prs
participant "Evaluator" as eval
participant "Linter" as lint
participant "Visualizer" as vis

== evaluate command ==

User -> cli : evaluate --policies p.cedar --request req.json
cli -> prs : parse(cedarText)
prs -> lex : tokenize(cedarText)
lex --> prs : Token[]
prs --> cli : Policy[]
cli -> eval : evaluate(policies, request)
eval -> eval : check forbid policies (deny-overrides)
eval -> eval : check permit policies
eval --> cli : Decision { allowed, matchedPolicy, reason }
cli --> User : print decision

== lint command ==

User -> cli : lint --policies p.cedar
cli -> prs : parse(cedarText)
prs --> cli : Policy[]
cli -> lint : lint(policies)
lint -> lint : check overly-permissive
lint -> lint : check no-forbid-policies
lint -> lint : check unconstrained-action
lint -> lint : check missing-tenant-check
lint --> cli : LintResult[]
cli --> User : print findings

== visualize command ==

User -> cli : visualize --policies p.cedar --request req.json
cli -> prs : parse(cedarText)
prs --> cli : Policy[]
cli -> vis : visualize(policies, request)
vis -> eval : evaluateAll(policies, request)
eval --> vis : PolicyEvaluation[]
vis --> cli : decision tree (text)
cli --> User : print tree

@enduml
